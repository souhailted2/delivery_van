{
  "name": "erp-van-sales-desktop",
  "version": "1.0.0",
  "description": "ERP Van Sales - تطبيق إدارة مبيعات الشاحنات",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-renderer": "node build-renderer.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "dist:all": "node build-renderer.mjs && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.alllal.erp-van-sales",
    "productName": "ERP Van Sales",
    "copyright": "Copyright © 2024",
    "directories": {
      "buildResources": "build",
      "output": "dist-installer"
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/.bin"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ERP Van Sales",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
